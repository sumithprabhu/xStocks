utputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"token\",\"type\":\"address\"},{\"internalType\":\"uint256[]\",\"name\":\"expiries\",\"type\":\"uint256[]\"},{\"internalType\":\"uint256[]\",\"name\":\"prices\",\"type\":\"uint256[]\"},{\"internalType\":\"uint256[]\",\"name\":\"highs\",\"type\":\"uint256[]\"},{\"internalType\":\"uint256[]\",\"name\":\"lows\",\"type\":\"uint256[]\"}],\"name\":\"setResolutionDataBatch\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"},{\"inputs\":[{\"internalType\":\"address\",\"name\":\"newOwner\",\"type\":\"address\"}],\"name\":\"transferOwnership\",\"outputs\":[],\"stateMutability\":\"nonpayable\",\"type\":\"function\"}],\"devdoc\":{\"kind\":\"dev\",\"methods\":{},\"stateVariables\":{\"_marketState\":{\"details\":\"Market state per token \\u2014 pushed by backend alongside price updates.\"},\"_resolutionData\":{\"details\":\"Resolution data per token per bucket expiry.      token => bucketExpiry => ResolutionData\"},\"lastUpdated\":{\"details\":\"Unix timestamp of the last spot-price update per token.\"},\"latestPrice\":{\"details\":\"Latest spot price per token (6 dec).\"}},\"title\":\"PriceFeed\",\"version\":1},\"userdoc\":{\"kind\":\"user\",\"methods\":{\"feeder()\":{\"notice\":\"The backend wallet address authorised to push prices.\"},\"getLatestPrice(address)\":{\"notice\":\"Returns the latest price and how stale it is (seconds since update).\"},\"getMarketState(address)\":{\"notice\":\"Returns the market state for a token.\"},\"getResolutionData(address,uint256)\":{\"notice\":\"Returns settlement data for a bucket, plus whether it has been pushed.\"},\"setPrice(address,uint256,bool,bool,bool,bool,bool)\":{\"notice\":\"Push a live spot price + market state for a token.         Called by the backend on every price tick from the xStocks API.\"},\"setPriceBatch(address[],uint256[])\":{\"notice\":\"Batch-push spot prices for multiple to